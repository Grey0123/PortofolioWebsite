# =========================================================================
# Next.js frontend env — copy to .env.local and fill in real values.
# =========================================================================
#
# After this refactor the FRONTEND no longer talks to Supabase directly:
# all reads/writes go through the FastAPI backend in /api. The only env
# var the frontend needs is the URL of that backend.
#
# The Supabase URL/anon key entries are kept commented out in case you
# want to run a quick experiment hitting Supabase directly from the
# browser. Production code paths don't read them anymore.
# =========================================================================

# URL of the FastAPI backend (see /api). In dev that's localhost:8000;
# in production it's whatever URL you deploy the API to.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Optional / legacy ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
