# =========================================================
# FastAPI backend environment.
# Copy this file to .env and fill in real values BEFORE running uvicorn.
# Never commit .env (it's git-ignored at the repo root).
# =========================================================

# --- Supabase ---
# Same project URL as the Next.js side.
SUPABASE_URL=https://your-project.supabase.co

# IMPORTANT: this is the SERVICE ROLE key (or "secret" key in the new
# Supabase naming). It bypasses RLS, so it MUST stay on the server
# (never reach the browser). The whole reason we have a FastAPI layer
# is to keep this key safe while still letting the frontend read/write
# data through controlled endpoints.
#
# Format: legacy keys start with "eyJ..." (JWT); new keys start with
# "sb_secret_...". Either works with supabase-py >= 2.15.
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# --- CORS ---
# Comma-separated list of origins allowed to call this API. In dev that's
# typically the Next.js dev server. In production, your deployed frontend URL.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Server (optional) ---
# Bind address + port for uvicorn. Defaults are fine for local dev.
API_HOST=0.0.0.0
API_PORT=8000
